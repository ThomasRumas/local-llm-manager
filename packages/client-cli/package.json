{
  "name": "@thomasrumas/llm-client",
  "version": "1.0.0",
  "description": "CLI client to remotely manage local LLM inference servers",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "llm-client": "./dist/index.js"
  },
