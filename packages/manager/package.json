    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@huggingface/hub": "^1.1.2",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.16.4",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "ink-testing-library": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
