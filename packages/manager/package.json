{
  "name": "@thomasrumas/llm-manager",
  "version": "1.1.1",
  "description": "A TUI to manage LLM powered by Llama.cpp",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "llm-manager": "dist/index.js",
    "llm-manager-daemon": "dist/daemon.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
